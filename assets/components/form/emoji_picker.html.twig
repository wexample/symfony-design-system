<div {{ component_render_tag_attributes({class:'form--group form--group-emoji-picker'}) }}>
    <label class="form--label" for="{{ id }}">{{ label }}</label>
    <div class="form--emoji-picker-control">
        <input
            class="form--input-emoji-picker"
            id="{{ id }}"
            type="hidden"
            {% if name is defined %}name="{{ name }}"{% endif %}
            {% if required is defined and required %}required{% endif %}
            {% if value is defined and value_attr is not defined %}value="{{ value }}"{% endif %}
            {% if value_attr is defined %}{{ value_attr|raw }}{% endif %}
            {% if input_attr is defined %}{{ input_attr|raw }}{% endif %}
        >
        <button
            class="form--emoji-picker-toggle button"
            type="button"
            aria-label="{{ "@component::label.open_picker" | trans }}"
            aria-expanded="false"
        >{{ value|default('😀') }}</button>
        <div class="form--emoji-picker-panel" hidden></div>
    </div>
</div>
