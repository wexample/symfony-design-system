<div class="banner{% if type is defined and type %} banner--{{ type }}{% endif %}">
    <button class="banner--close" type="button" data-banner-close>
        {{ icon('ph:bold/x') }}
    </button>
    {% if title is defined and title %}
        <div class="banner--title">{{ title }}</div>
    {% endif %}
    {% if message is defined and message %}
        <div class="banner--message">{{ message }}</div>
    {% endif %}
</div>
